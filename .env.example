# === Serviços Externos (na rede ia-local_default) ===
OLLAMA_URL=http://ollama_ia:11434
QDRANT_URL=http://qdrant_vector_db_ia:6333
DATABASE_URL=postgresql+asyncpg://admin:senha_segura_db@postgres_db_ia:5432/painel_rag
REDIS_URL=redis://redis_cache_ia:6379

# === LLM ===
LLM_MODEL=llama3
EMBEDDING_MODEL=nomic-embed-text

# === SuperAdmin (criado automaticamente no primeiro boot) ===
SUPERADMIN_EMAIL=admin@camara.gov.br
SUPERADMIN_PASSWORD=Admin@2024
SUPERADMIN_NOME=Super Administrador

# === JWT ===
JWT_SECRET=troque-por-uma-chave-segura-de-64-caracteres
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === Qdrant ===
QDRANT_COLLECTION=camara_documentos

# === Upload ===
MAX_UPLOAD_SIZE_MB=50
